round:#7C3AED;color:#fff;font-size:16px;font-weight:600;text-decoration:none;padding:16px 40px;border-radius:10px\">{{ $('Code Enrich').item.json.sector.ctaLabel }} →</a>\n    </td></tr></table>\n  </td></tr>\n  <tr><td style=\"padding:24px 40px;border-top:1px solid #F3F4F6\">\n    <p style=\"margin:0;font-size:12px;color:#9CA3AF;text-align:center\">Recibiste este email porque te registraste en pacienteia.com.<br>Si no fuiste tú, ignora este mensaje.</p>\n  </td></tr>\n</table>\n</td></tr></table></body></html>"
