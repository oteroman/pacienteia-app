      "position": [320, 300],
      "parameters": {
        "jsCode": "const sectorData = {\n  estetica: {\n    label: 'Centro de Estética',\n    metric: 'Las clínicas estéticas reducen 40% los no-shows con recordatorios automáticos.',\n    pain: 'cada turno perdido es una cabina vacía que no genera ingresos',\n    demoHook: 'Te mostramos cómo una clínica estética en Lima redujo sus cancelaciones a la mitad en 30 días.',\n    ctaLabel: 'Activar recordatorios automáticos',\n    emoji: '✨'\n  },\n  odontologia: {\n    label: 'Consultorio Dental',\n    metric: 'Los consultorios dentales recuperan hasta S/3,000 al mes en citas que habrían quedado vacías.',\n    pain: 'cada silla vacía son ingresos que no vuelven',\n    demoHook: 'Te mostramos cómo un dentista en Miraflores llenó su agenda en 2 semanas.',\n    ctaLabel: 'Llenar mi agenda hoy',\n    emoji: '🦷'\n  },\n  psicologia: {\n    label: 'Consultorio de Psicología',\n    metric: 'Los psicólogos con recordatorios automáticos tienen 35% menos cancelaciones de último minuto.',\n    pain: 'las cancelaciones de última hora interrumpen el vínculo terapéutico',\n    demoHook: 'Te mostramos cómo un psicólogo en San Isidro recuperó 6 sesiones al mes.',\n    ctaLabel: 'Reducir mis cancelaciones',\n    emoji: '🧠'\n  },\n  medicos: {\n    label: 'Consultorio Médico',\n    metric: 'Las clínicas médicas con IA reducen 45% los no-shows y mejoran la satisfacción del paciente.',\n    pain: 'los pacientes que no asisten generan costos operativos que se acumulan silenciosamente',\n    demoHook: 'Te mostramos cómo un médico en Lima Norte optimizó su agenda en una semana.',\n    ctaLabel: 'Optimizar mi agenda',\n    emoji: '🩺'\n  }\n};\n\nconst rubro = ($input.item.json.rubro || 'medicos').toLowerCase();\nconst email = ($input.item.json.email || '').toLowerCase().trim();\nconst sector = sectorData[rubro] || sectorData['medicos'];\n\nif (!email || !email.includes('@')) {\n  throw new Error('Email inválido: ' + email);\n}\n\nreturn [{\n  json: {\n    email,\n    rubro,\n    sector,\n    timestamp: new Date().toISOString(),\n    signupUrl: 'https://app.pacienteia.com/signup',\n    fromName: 'Paciente IA',\n    fromEmail: 'hola@pacienteia.com'\n  }\n}];"
      }
    },
